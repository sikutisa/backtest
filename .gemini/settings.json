{
  "security": {
    "commandAllowList": [
      "git",
      "./gradlew",
      "java",
      "docker",
      "ls",
      "find",
      "grep"
    ],
    "commandBlockList": [
      "rm -rf",
      "sudo",
      "format",
      "mkfs",
      "chmod 777"
    ]
  },
  "mcpServers": {
    "local-infra": {
      "command": "node",
      "args": [
        "infra-server.js"
      ],
      "env": {
        "DOCKER_API_VERSION": "1.41"
      },
      "trust": false
    }
  },
  "tools": {
    "core": [
      "read_file",
      "write_file",
      "run_shell_command",
      "grep_search",
      "glob",
      "replace",
      "save_memory",
      "cli_help"
    ]
  }
}
